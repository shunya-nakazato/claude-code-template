{
  "permissions": {
    "allow": [
      "WebSearch",

      "Bash(cat ./*)",
      "Bash(echo *)",
      "Bash(ls *)",
      "Bash(find *)",
      "Bash(tree ./*)",
      "Bash(mkdir -p ./*)",
      "Bash(chmod +x ./*)",

      "Bash(git add:*)",
      "Bash(git branch:*)",
      "Bash(git checkout:*)",
      "Bash(git commit:*)",
      "Bash(git diff:*)",
      "Bash(git log:*)",
      "Bash(git mv ./* ./*)",
      "Bash(git pull:*)",
      "Bash(git rm:*)",
      "Bash(git show:*)",
      "Bash(git stash:*)",
      "Bash(git status:*)",

      "Bash(docker compose *)",
      "Bash(docker ps *)",
      "Bash(docker logs *)",

      "Bash(npm install)",
      "Bash(npm run *)",
      "Bash(npx tsc *)",
      "Bash(npx next lint)",

      "Bash(./.claude/scripts/*.sh:*)",
      "Bash(./.claude/scripts/codex.sh:*)",
      "Bash(./.claude/scripts/test.sh:*)",

      "Edit(./*)",
      "Write(./*)"
    ],
    "deny": [
      "Bash(rm -rf *)",

      "Edit(/*)",
      "Edit(~/*)",
      "Edit(../*)",
      "Edit(../../*)",

      "Write(/*)",
      "Write(~/*)",
      "Write(../*)",
      "Write(../../*)"
    ]
  },
  "sandbox": {
    "enabled": true,
    "autoAllowBashIfSandboxed": true
  }
}